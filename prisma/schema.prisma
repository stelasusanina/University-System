generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique @db.VarChar(200)
  password        String   @db.VarChar(255)
  role            UserRole
  studentId       Int?     @unique
  academicStaffId Int?     @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student       Student?       @relation(fields: [studentId], references: [id])
  academicStaff AcademicStaff? @relation(fields: [academicStaffId], references: [id])
  pushTokens    PushToken[]
}

model Faculty {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(200)
  code        String   @unique @db.VarChar(10)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  specialties          Specialty[]
  academicStaffMembers AcademicStaff[]
}

model Specialty {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(200)
  code      String   @unique @db.VarChar(20)
  degree    Degree   @default(BACHELOR)
  years     Int      @default(4)
  facultyId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  faculty Faculty @relation(fields: [facultyId], references: [id])

  groups Group[]
}

model Group {
  id          Int @id @default(autoincrement())
  number      Int
  studyYear   Int
  specialtyId Int

  specialty Specialty @relation(fields: [specialtyId], references: [id])

  students      Student[]
  semesters     StudentSemester[]
  courseGroups  CourseGroup[]
  schedules     Schedule[]
  events        Event[]
  announcements Announcement[]

  @@unique([number, studyYear, specialtyId])
}

model Student {
  id            Int      @id @default(autoincrement())
  facultyNumber String   @unique @db.VarChar(20)
  firstName     String   @db.VarChar(100)
  lastName      String   @db.VarChar(100)
  phone         String?  @db.VarChar(20)
  groupId       Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  group     Group     @relation(fields: [groupId], references: [id])
  semesters StudentSemester[]
  grades    Grade[]

  user User?
}

model StudentSemester {
  id         Int @id @default(autoincrement())

  studentId  Int
  semesterId Int

  status StudentStatus @default(ACTIVE)

  student  Student  @relation(fields: [studentId], references: [id])
  semester Semester @relation(fields: [semesterId], references: [id])

  @@unique([studentId, semesterId])
}

model AcademicStaff {
  id          Int           @id @default(autoincrement())
  staffNumber String        @unique @db.VarChar(20)
  firstName   String        @db.VarChar(100)
  lastName    String        @db.VarChar(100)
  phone       String?       @db.VarChar(20)
  title       AcademicTitle @default(ASSISTANT)
  facultyId   Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  faculty       Faculty        @relation(fields: [facultyId], references: [id])
  courses       Course[]
  schedules     Schedule[]
  events        Event[]
  announcements Announcement[]
  materials     Material[]
  user          User?
}

model Course {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(200)
  code        String     @unique @db.VarChar(20)
  description String?    @db.Text
  credits     Int
  type        CourseType @default(MANDATORY)
  academicStaffId Int

  academicStaff AcademicStaff @relation(fields: [academicStaffId], references: [id])

  courseGroups  CourseGroup[]
  schedules     Schedule[]
  events        Event[]
  announcements Announcement[]
  materials     Material[]
}

model CourseGroup {
  id                 Int @id @default(autoincrement())
  courseId           Int
  groupId            Int
  curriculumSemester Int

  course Course @relation(fields: [courseId], references: [id])
  group  Group  @relation(fields: [groupId], references: [id])

  grades Grade[]

  @@unique([courseId, groupId])
}

model Grade {
  id            Int   @id @default(autoincrement())
  studentId     Int
  courseGroupId Int
  finalGrade    Float

  student     Student     @relation(fields: [studentId], references: [id])
  courseGroup CourseGroup @relation(fields: [courseGroupId], references: [id])

  @@unique([studentId, courseGroupId])
}

model Semester {
  id        Int            @id @default(autoincrement())
  name      String         @db.VarChar(50)
  period    SemesterPeriod
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean        @default(false)

  studentSemesters StudentSemester[]
  schedules        Schedule[]
  events           Event[]
  announcements    Announcement[]
}

model Schedule {
  id              Int        @id @default(autoincrement())

  courseId        Int
  academicStaffId Int
  semesterId      Int
  groupId         Int

  dayOfWeek       DayOfWeek
  startTime       String     @db.VarChar(5)
  endTime         String     @db.VarChar(5)
  room            String     @db.VarChar(50)
  type            LessonType @default(ЛЕКЦИЯ)

  course        Course        @relation(fields: [courseId], references: [id])
  academicStaff AcademicStaff @relation(fields: [academicStaffId], references: [id])
  semester      Semester      @relation(fields: [semesterId], references: [id])
  group         Group         @relation(fields: [groupId], references: [id])

  @@index([groupId])

  @@unique([
    groupId,
    semesterId,
    dayOfWeek,
    startTime
  ])
}

model Building {
  id            Int      @id @default(autoincrement())
  number        Int      @unique
  name          String   @db.VarChar(200)
  address       String   @db.VarChar(300)
  latitude      Float
  longitude     Float
  googleMapsUrl String?  @db.VarChar(1000)
}

model Announcement {
  id              Int              @id @default(autoincrement())
  message         String           @db.Text
  type            AnnouncementType @default(ИНФОРМАЦИЯ)
  validTo         DateTime
  academicStaffId Int
  courseId        Int?
  groupId         Int?
  semesterId      Int
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  academicStaff AcademicStaff @relation(fields: [academicStaffId], references: [id])
  course        Course?       @relation(fields: [courseId], references: [id])
  group         Group?        @relation(fields: [groupId], references: [id])
  semester      Semester      @relation(fields: [semesterId], references: [id])
}

model Material {
  id              Int      @id @default(autoincrement())
  title           String   @db.VarChar(300)
  description     String?  @db.Text
  fileUrl         String   @db.VarChar(1000)
  fileType        String   @db.VarChar(10)
  courseId        Int
  academicStaffId Int
  uploadedAt      DateTime @default(now())

  course        Course        @relation(fields: [courseId], references: [id])
  academicStaff AcademicStaff @relation(fields: [academicStaffId], references: [id])
}

model Event {
  id              Int       @id @default(autoincrement())
  title           String    @db.VarChar(300)
  type            EventType
  date            DateTime  @db.Date
  startTime       String?   @db.VarChar(5)
  endTime         String?   @db.VarChar(5)
  room            String?   @db.VarChar(50)
  courseId        Int
  academicStaffId Int
  groupId         Int?
  semesterId      Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  course        Course        @relation(fields: [courseId], references: [id])
  academicStaff AcademicStaff @relation(fields: [academicStaffId], references: [id])
  group         Group?        @relation(fields: [groupId], references: [id])
  semester      Semester      @relation(fields: [semesterId], references: [id])
}

model PushToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(200)
  userId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AnnouncementType {
  ИНФОРМАЦИЯ
  ОТМЯНА
  ЗАКЪСНЕНИЕ
  СМЯНА_НА_ЗАЛА
  СПЕШНО
}

enum UserRole {
  PROFESSOR
  ASSOCIATE_PROFESSOR
  SENIOR_ASSISTANT
  ASSISTANT
  STUDENT
}

enum Degree {
  BACHELOR
  MASTER
  DOCTORATE
}

enum StudentStatus {
  ACTIVE
  GRADUATED
  SUSPENDED
  DROPPED
}

enum AcademicTitle {
  ASSISTANT
  SENIOR_ASSISTANT
  ASSOCIATE_PROFESSOR
  PROFESSOR
}

enum CourseType {
  MANDATORY
  ELECTIVE
}

enum SemesterPeriod {
  WINTER
  SUMMER
}

enum DayOfWeek {
  ПОНЕДЕЛНИК
  ВТОРНИК
  СРЯДА
  ЧЕТВЪРТЪК
  ПЕТЪК
}

enum LessonType {
  ЛЕКЦИЯ
  СЕМИНАРНО_УПРАЖНЕНИЕ
  ЛАБОРАТОРНО_УПРАЖНЕНИЕ
}

enum EventType {
  КОНТРОЛНА
  ИЗПИТ
  ЗАДАНИЕ
  ЗАЩИТА_НА_ПРОЕКТ
  ДРУГО
}
