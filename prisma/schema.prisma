generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique @db.VarChar(200)
  password        String   @db.VarChar(255)
  role            UserRole
  studentId       Int?     @unique
  academicStaffId Int?     @unique
  createdAt       DateTime @default(now())

  student       Student?       @relation(fields: [studentId], references: [id])
  academicStaff AcademicStaff? @relation(fields: [academicStaffId], references: [id])
  pushTokens    PushToken[]
}

model PushToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(200)
  userId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Faculty {
  id          Int     @id @default(autoincrement())
  name        String  @unique @db.VarChar(200)
  code        String  @unique @db.VarChar(5)
  description String? @db.Text

  specialties          Specialty[]
  academicStaffMembers AcademicStaff[]
}

model Specialty {
  id        Int    @id @default(autoincrement())
  name      String @db.VarChar(200)
  code      String @unique @db.VarChar(5)
  degree    Degree @default(БАКАЛАВЪР)
  years     Int    @default(4)
  facultyId Int

  faculty Faculty @relation(fields: [facultyId], references: [id])
  groups  Group[]
}

model Group {
  id          Int @id @default(autoincrement())
  number      Int
  studyYear   Int
  specialtyId Int

  specialty Specialty @relation(fields: [specialtyId], references: [id])

  students     Student[]
  courseGroups CourseGroup[]

  @@unique([number, studyYear, specialtyId])
}

model Student {
  id            Int      @id @default(autoincrement())
  facultyNumber String   @unique @db.Char(10)
  firstName     String   @db.VarChar(100)
  lastName      String   @db.VarChar(100)
  phone         String?  @db.Char(10)
  groupId       Int
  role          UserRole @default(СТУДЕНТ)

  group  Group   @relation(fields: [groupId], references: [id])
  grades Grade[]

  user User?
}

model AcademicStaff {
  id          Int      @id @default(autoincrement())
  staffNumber String   @unique @db.Char(10)
  firstName   String   @db.VarChar(100)
  lastName    String   @db.VarChar(100)
  phone       String?  @db.Char(10)
  role        UserRole @default(АСИСТЕНТ)
  facultyId   Int

  faculty       Faculty        @relation(fields: [facultyId], references: [id])
  user          User?
  courseGroups  CourseGroup[]
  announcements Announcement[]
  events        Event[]
  materials     Material[]
}

model Course {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(200)
  code        String     @unique @db.VarChar(5)
  description String?    @db.Text
  credits     Int

  courseGroups CourseGroup[]
  materials    Material[]
}

model Semester {
  id           Int            @id @default(autoincrement())
  academicYear String         @db.VarChar(20)
  period       SemesterPeriod
  startDate    DateTime
  endDate      DateTime
  isCurrent    Boolean        @default(false)

  courseGroups CourseGroup[]
}

model CourseGroup {
  id              Int @id @default(autoincrement())
  courseId        Int
  groupId         Int
  academicStaffId Int
  semesterNum     Int
  semesterId      Int

  course        Course        @relation(fields: [courseId], references: [id])
  group         Group         @relation(fields: [groupId], references: [id])
  academicStaff AcademicStaff @relation(fields: [academicStaffId], references: [id])
  semester      Semester      @relation(fields: [semesterId], references: [id])

  grades        Grade[]
  schedules     Schedule[]
  announcements Announcement[]
  events        Event[]

  @@unique([courseId, groupId, semesterId])
}

model Grade {
  id            Int   @id @default(autoincrement())
  studentId     Int
  courseGroupId Int
  finalGrade    Float

  student     Student     @relation(fields: [studentId], references: [id])
  courseGroup CourseGroup @relation(fields: [courseGroupId], references: [id])

  @@unique([studentId, courseGroupId])
}

model Schedule {
  id            Int @id @default(autoincrement())
  courseGroupId Int

  dayOfWeek DayOfWeek
  startTime String    @db.VarChar(5)
  endTime   String    @db.VarChar(5)
  room      String    @db.VarChar(50)

  type LessonType @default(ЛЕКЦИЯ)

  courseGroup CourseGroup @relation(fields: [courseGroupId], references: [id])
}

model Material {
  id              Int      @id @default(autoincrement())
  title           String   @db.VarChar(300)
  description     String?  @db.Text
  fileUrl         String   @db.VarChar(1000)
  fileType        String   @db.VarChar(10)
  courseId        Int
  academicStaffId Int
  uploadedAt      DateTime @default(now())

  course        Course        @relation(fields: [courseId], references: [id])
  academicStaff AcademicStaff @relation(fields: [academicStaffId], references: [id])
}

model Announcement {
  id              Int              @id @default(autoincrement())
  message         String           @db.Text
  type            AnnouncementType @default(ИНФОРМАЦИЯ)
  validTo         DateTime
  academicStaffId Int
  courseGroupId   Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  academicStaff AcademicStaff @relation(fields: [academicStaffId], references: [id])
  courseGroup   CourseGroup?  @relation(fields: [courseGroupId], references: [id])
}

model Event {
  id              Int       @id @default(autoincrement())
  title           String    @db.VarChar(300)
  type            EventType
  date            DateTime  @db.Date
  startTime       String?   @db.VarChar(5)
  endTime         String?   @db.VarChar(5)
  room            String?   @db.VarChar(50)
  courseGroupId   Int
  academicStaffId Int
  createdAt       DateTime  @default(now())

  courseGroup   CourseGroup   @relation(fields: [courseGroupId], references: [id])
  academicStaff AcademicStaff @relation(fields: [academicStaffId], references: [id])
}

model Building {
  id            Int     @id @default(autoincrement())
  number        Int     @unique
  name          String  @db.VarChar(200)
  address       String  @db.VarChar(300)
  latitude      Float
  longitude     Float
  googleMapsUrl String? @db.VarChar(1000)
}

enum AnnouncementType {
  ИНФОРМАЦИЯ
  ОТМЯНА
  ЗАКЪСНЕНИЕ
  СМЯНА_НА_ЗАЛА
  СПЕШНО
}

enum UserRole {
  ПРОФЕСОР
  ДОЦЕНТ
  ГЛАВЕН_АСИСТЕНТ
  АСИСТЕНТ
  СТУДЕНТ
}

enum Degree {
  БАКАЛАВЪР
  МАГИСТЪР
  ДОКТОРАНТ
}

enum SemesterPeriod {
  ЗИМЕН
  ЛЕТЕН
}

enum DayOfWeek {
  ПОНЕДЕЛНИК
  ВТОРНИК
  СРЯДА
  ЧЕТВЪРТЪК
  ПЕТЪК
}

enum LessonType {
  ЛЕКЦИЯ
  СЕМИНАРНО_УПРАЖНЕНИЕ
  ЛАБОРАТОРНО_УПРАЖНЕНИЕ
}

enum EventType {
  КОНТРОЛНА
  ИЗПИТ
  ЗАДАНИЕ
  ЗАЩИТА_НА_ПРОЕКТ
  ДРУГО
}
